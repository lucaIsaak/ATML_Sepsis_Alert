# SepsisAlert — environment variable template
# Copy to .env and fill in values before running in production.
# The application works without a .env file for local demo (defaults are used).

# ── API server ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (no spaces).
# Default (if unset): http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Ollama (local LLM for narrative generation) ────────────────────────────
# Override if Ollama runs on a different host/port (e.g. a dedicated GPU node).
# Default (if unset): http://localhost:11434  (set in config.yaml)
# OLLAMA_BASE_URL=http://localhost:11434

# ── Logging ────────────────────────────────────────────────────────────────
# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
