# SepsisAlert environment variables
# Copy to .env and adjust as needed:
#   cp .env.example .env

# CORS origins allowed by the FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Ollama base URL — use host.docker.internal when Ollama runs on the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
