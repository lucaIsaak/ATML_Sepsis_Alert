# Copy this to .env and fill in your values
# Never commit .env to git

# Claude API (optional — only needed if narrative.provider = "claude")
ANTHROPIC_API_KEY=your_key_here

# HuggingFace (optional — only needed if narrative.provider = "huggingface")
HUGGINGFACE_TOKEN=your_token_here

# Ollama runs locally — no key needed

# CORS — comma-separated list of allowed frontend origins (default: localhost only)
# Set this when deploying to a staging URL or sharing with teammates
# CORS_ORIGINS=http://localhost:5173,https://your-staging-url.com
