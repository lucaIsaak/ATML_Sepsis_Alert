# SepsisAlert environment variables
# Copy to .env and adjust as needed:
#   cp .env.example .env

# CORS origins allowed by the FastAPI backend (comma-separated)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Ollama base URL — use host.docker.internal when Ollama runs on the host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Whisper model for voice transcription: tiny | base | small | medium | large
# small (~244 MB) is the recommended default — good accuracy, ~5s for a 30s clip
# medium (~769 MB) for better accuracy at the cost of ~15s transcription time
WHISPER_MODEL=small

# Anthropic Claude API key — only required if narrative.provider: "claude" in config.yaml
# Get your key at https://console.anthropic.com
# GDPR: a signed Data Processing Agreement (DPA) with Anthropic is required before enabling
# the Claude backend in a clinical environment (GDPR Art. 28).
# ANTHROPIC_API_KEY=sk-ant-...
